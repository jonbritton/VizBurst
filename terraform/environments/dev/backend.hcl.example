# Copy to backend.hcl (gitignored) and fill in the bucket the bootstrap stack
# created, then: tofu init -backend-config=backend.hcl
bucket         = "YOUR-TFSTATE-BUCKET"
key            = "render-farm/dev/terraform.tfstate"
region         = "us-west-2"
dynamodb_table = "devops-portfolio-tfstate-lock"
encrypt        = true
